PORT=5000
DB_URL=mongodb://localhost:27017/notebookLM
JWT_SECRET=replace_with_jwt_secret

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_redis_password

# Hugging Face RAG configuration
HUGGINGFACE_API_KEY=hf_replace_with_your_token
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
HF_RERANKER_MODEL=BAAI/bge-reranker-large
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_LLM_FALLBACK_MODELS=meta-llama/Llama-3.2-3B-Instruct,Qwen/Qwen2.5-7B-Instruct,mistralai/Mistral-7B-Instruct-v0.3
HF_INFERENCE_BASE_URL=https://router.huggingface.co/hf-inference/models
HF_CHAT_COMPLETIONS_URL=https://router.huggingface.co/v1/chat/completions

# Retrieval and chunking controls
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
RAG_RETRIEVAL_TOP_K=20
RAG_RERANK_TOP_N=5

# Optional pipeline controls
VECTOR_DB_BACKEND=in-memory
# Set to "faiss" when a FAISS Node adapter is installed and wired.
